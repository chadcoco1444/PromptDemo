NEXT_PUBLIC_API_BASE=http://localhost:3000

# Auth (set AUTH_ENABLED=true to activate NextAuth + Postgres adapter)
# AUTH_ENABLED=true
# AUTH_SECRET=
# DATABASE_URL=postgres://lumespec:lumespec@localhost:5432/lumespec

# Google OAuth (required when AUTH_ENABLED=true)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — omit to hide the GitHub sign-in button)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
