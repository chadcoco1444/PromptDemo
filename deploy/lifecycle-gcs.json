{
  "lifecycle": {
    "rule": [
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 7,
          "matchesPrefix": ["jobs/"],
          "matchesSuffix": ["/crawlResult.json"]
        }
      },
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 7,
          "matchesPrefix": ["jobs/"],
          "matchesSuffix": ["/storyboard.json"]
        }
      },
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 365,
          "matchesPrefix": ["jobs/"],
          "matchesSuffix": ["/video.mp4"]
        }
      },
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 365,
          "matchesPrefix": ["jobs/"],
          "matchesSuffix": ["/thumb.webp"]
        }
      }
    ]
  }
}
