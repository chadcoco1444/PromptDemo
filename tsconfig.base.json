// Base TypeScript config. Per-package `tsconfig.json` extends this.
//
// Notes:
//  - `moduleResolution: "Bundler"` is used across the workspace. It works
//    for Next.js (apps/web), Remotion (packages/remotion), and Node workers
//    (workers/*) as long as workers run via `tsx` (which tolerates
//    extensionless imports). If a worker is ever compiled and run via
//    `node dist/*.js` instead of `tsx`, it will need to switch back to
//    NodeNext and add `.js` suffixes to local imports.
//  - `lib` intentionally excludes "DOM". Browser packages add it back
//    (e.g. `"lib": ["ES2022", "DOM"]`). Keeps Node workers honest.
//  - `composite` is intentionally omitted. Packages that want TypeScript
//    project references opt in by setting `"composite": true` in their
//    own tsconfig.
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
