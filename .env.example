# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# S3 / MinIO (dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=lumespec-dev
S3_FORCE_PATH_STYLE=true

# Crawler
CRAWLER_RESCUE_ENABLED=false
SCREENSHOTONE_ACCESS_KEY=
PLAYWRIGHT_TIMEOUT_MS=15000

# Anthropic (Plan 2) — REQUIRED
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=4096

# Next.js web (Plan 6) — read by client bundle
NEXT_PUBLIC_API_BASE=http://localhost:3000
NEXT_PUBLIC_S3_ENDPOINT=http://localhost:9000

# Google OAuth (Feature 4 Auth) — create at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3001
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Internal trust boundary between Next.js BFF and Fastify apps/api.
# Mints a 60s JWT that carries the user id signed; replaces v1's plaintext
# X-User-Id header. MUST be at least 32 chars. Both apps/web and apps/api
# need the same value.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# BFF rate limit (per ip+userId, sliding 1-minute window)
BFF_RATE_LIMIT_PER_MIN=20

# Postgres (Feature 4 Auth persistence)
DATABASE_URL=postgresql://lumespec:lumespec@localhost:5432/lumespec

# Feature flags
AUTH_ENABLED=false           # set "true" once OAuth creds + AUTH_SECRET + Postgres are configured
PRICING_ENABLED=false        # set "true" once Stripe keys are configured (Feature 5)
BUDGET_GUARD_ENABLED=false   # set "true" to enforce Anthropic daily spend cap (Phase 5.1)

# Phase 5.1 — Anthropic daily spend guard (only read when BUDGET_GUARD_ENABLED=true).
# Token-cost rates are also overridable here; defaults match Sonnet 4.6 list pricing.
# CLAUDE_INPUT_RATE_USD_PER_MTOK=3
# CLAUDE_OUTPUT_RATE_USD_PER_MTOK=15

# Stripe (Feature 5 Pricing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=

# Dev mode
MOCK_MODE=false
NODE_ENV=development
